---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.about-container {
				padding: 3rem 0;
				display: flex;
				flex-direction: column;
				gap: 3rem;
			}
			
			.about-hero {
				text-align: center;
				padding: 2rem 0;
			}

			.about-title {
				font-size: 2.5rem;
				font-weight: 800;
				background: linear-gradient(135deg, #ffffff 40%, var(--accent-primary) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin-bottom: 0.5rem;
			}

			.about-subtitle {
				font-family: monospace;
				font-size: 0.95rem;
				color: var(--accent-secondary);
			}

			.about-grid {
				display: grid;
				grid-template-columns: 1.5fr 1fr;
				gap: 2rem;
			}

			.content-card {
				padding: 2.5rem;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.card-title {
				font-size: 1.5rem;
				font-weight: 700;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				padding-bottom: 0.5rem;
				color: var(--text-primary);
			}

			.card-text {
				font-size: 0.95rem;
				color: var(--text-secondary);
				line-height: 1.7;
			}

			.highlight-box {
				background: rgba(6, 182, 212, 0.05);
				border: 1px solid rgba(6, 182, 212, 0.15);
				border-radius: 8px;
				padding: 1rem;
				font-family: monospace;
				font-size: 0.85rem;
				color: var(--accent-secondary);
			}

			.meta-list {
				list-style-type: none;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.meta-item {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}

			.meta-label {
				font-family: monospace;
				font-size: 0.75rem;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.meta-value {
				font-size: 0.95rem;
				color: var(--text-primary);
				font-weight: 600;
			}

			@media (max-width: 768px) {
				.about-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="about-container">
				
				<div class="about-hero">
					<h1 class="about-title">Vishal Chepyala</h1>
					<span class="about-subtitle">// System Architect & Agency Founder</span>
				</div>

				<div class="about-grid">
					
					<div class="glass-panel content-card">
						<h2 class="card-title">My Philosophy</h2>
						<p class="card-text">
							I operate at the intersection of business systems and hardware interface programming. I don't build placeholder mockups; I build working software engines and reverse engineer communication protocols to bridge low-level logic with production application networks.
						</p>
						<p class="card-text">
							With a background in <strong>Computer Science and Engineering</strong>, my core drive is understanding how systems work from the physical registers to the high-level API orchestrations. Whether it is scanning Xiaomi MIIO packets or building asynchronous data pipelines for cold email agencies, my goal is to maximize performance, reduce development friction, and use AI tools to ship code at the speed of thought.
						</p>
						<div class="highlight-box">
							$ systeminfo --status<br />
							> CSE undergraduate building the future of automated agent integrations.<br />
							> Currently optimizing local network robotics APIs.
						</div>
					</div>

					<div class="glass-panel content-card">
						<h2 class="card-title">System Metrics</h2>
						<ul class="meta-list">
							<li class="meta-item">
								<span class="meta-label">Origin</span>
								<span class="meta-value">Hyderabad, India</span>
							</li>
							<li class="meta-item">
								<span class="meta-label">Affiliation</span>
								<span class="meta-value">Vardhaman College of Engineering</span>
							</li>
							<li class="meta-item">
								<span class="meta-label">Focus Area</span>
								<span class="meta-value">IoT & AI Automation Pipelines</span>
							</li>
							<li class="meta-item">
								<span class="meta-label">Active Ventures</span>
								<span class="meta-value">KC Alpha Media & Bridgr</span>
							</li>
						</ul>
					</div>

				</div>

			</div>
		</main>
		<Footer />
	</body>
</html>
