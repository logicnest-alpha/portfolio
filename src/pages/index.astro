		<!-- Dynamic Interactive Tensegrity Script -->
		<script>
			// Cable connection illumination script
			document.addEventListener('DOMContentLoaded', () => {
				const projectCards = document.querySelectorAll('.project-card');
				
				projectCards.forEach(card => {
					card.addEventListener('mouseenter', () => {
						const cableIds = card.getAttribute('data-cable-ids')?.split(',') || [];
						cableIds.forEach(id => {
							const lineElement = document.getElementById(id);
							if (lineElement) {
								lineElement.classList.add('active');
							}
						});
					});

					card.addEventListener('mouseleave', () => {
						const cableIds = card.getAttribute('data-cable-ids')?.split(',') || [];
						cableIds.forEach(id => {
							const lineElement = document.getElementById(id);
							if (lineElement) {
								lineElement.classList.remove('active');
							}
						});
					});
				});

				// Let's implement a simple 2D Tensegrity physics canvas
				const canvas = document.getElementById('tensegrityCanvas') as HTMLCanvasElement;
				if (!canvas) return;
				const ctx = canvas.getContext('2d');
				if (!ctx) return;

				let width = canvas.width = canvas.parentElement?.clientWidth || 800;
				let height = canvas.height = 300;

				window.addEventListener('resize', () => {
					if (!canvas.parentElement) return;
					width = canvas.width = canvas.parentElement.clientWidth;
				});

				// Tensegrity physics system
				interface Node {
					x: number;
					y: number;
					vx: number;
					vy: number;
					radius: number;
					color: string;
					label: string;
					tier: number;
					isStatic: boolean;
				}

				interface Cable {
					fromIdx: number;
					toIdx: number;
					restLength: number;
					stiffness: number;
					color: string;
				}

				let nodes: Node[] = [];
				let cables: Cable[] = [];

				function initPhysics() {
					nodes = [
						// Tier 3 (Top) - Static Anchor blog
						{ x: width / 2, y: 40, vx: 0, vy: 0, radius: 10, color: '#06b6d4', label: 'Tier 3: The Vault', tier: 3, isStatic: true },
						
						// Tier 2 (Middle) - Suspended Projects nodes
						{ x: width / 2 - 160, y: 130, vx: 0, vy: 0, radius: 14, color: '#8b5cf6', label: 'MiRobot', tier: 2, isStatic: false },
						{ x: width / 2 - 50, y: 130, vx: 0, vy: 0, radius: 14, color: '#8b5cf6', label: 'NutriGuard', tier: 2, isStatic: false },
						{ x: width / 2 + 50, y: 130, vx: 0, vy: 0, radius: 14, color: '#8b5cf6', label: 'LeadGen', tier: 2, isStatic: false },
						{ x: width / 2 + 160, y: 130, vx: 0, vy: 0, radius: 14, color: '#8b5cf6', label: 'Sangam', tier: 2, isStatic: false },
						
						// Tier 1 (Bottom) - Solid base blocks
						{ x: width / 2 - 100, y: 240, vx: 0, vy: 0, radius: 12, color: '#ec4899', label: 'Bio Base', tier: 1, isStatic: false },
						{ x: width / 2 + 100, y: 240, vx: 0, vy: 0, radius: 12, color: '#ec4899', label: 'Skills Grid', tier: 1, isStatic: false },
					];

					cables = [
						// Tier 3 to Tier 2 (Suspension)
						{ fromIdx: 0, toIdx: 1, restLength: 180, stiffness: 0.1, color: 'rgba(6, 182, 212, 0.4)' },
						{ fromIdx: 0, toIdx: 2, restLength: 120, stiffness: 0.1, color: 'rgba(6, 182, 212, 0.4)' },
						{ fromIdx: 0, toIdx: 3, restLength: 120, stiffness: 0.1, color: 'rgba(6, 182, 212, 0.4)' },
						{ fromIdx: 0, toIdx: 4, restLength: 180, stiffness: 0.1, color: 'rgba(6, 182, 212, 0.4)' },

						// Tier 2 internal strut constraints (compression)
						{ fromIdx: 1, toIdx: 2, restLength: 110, stiffness: 0.15, color: 'rgba(139, 92, 246, 0.3)' },
						{ fromIdx: 2, toIdx: 3, restLength: 100, stiffness: 0.15, color: 'rgba(139, 92, 246, 0.3)' },
						{ fromIdx: 3, toIdx: 4, restLength: 110, stiffness: 0.15, color: 'rgba(139, 92, 246, 0.3)' },

						// Tier 2 to Tier 1
						{ fromIdx: 1, toIdx: 5, restLength: 150, stiffness: 0.1, color: 'rgba(236, 72, 153, 0.4)' },
						{ fromIdx: 2, toIdx: 5, restLength: 120, stiffness: 0.1, color: 'rgba(236, 72, 153, 0.4)' },
						{ fromIdx: 3, toIdx: 6, restLength: 120, stiffness: 0.1, color: 'rgba(236, 72, 153, 0.4)' },
						{ fromIdx: 4, toIdx: 6, restLength: 150, stiffness: 0.1, color: 'rgba(236, 72, 153, 0.4)' },

						// Tier 1 bottom base tie
						{ fromIdx: 5, toIdx: 6, restLength: 200, stiffness: 0.2, color: 'rgba(236, 72, 153, 0.5)' }
					];
				}

				initPhysics();

				let selectedNode: number | null = null;

				canvas.addEventListener('mousedown', (e) => {
					const rect = canvas.getBoundingClientRect();
					const mouseX = e.clientX - rect.left;
					const mouseY = e.clientY - rect.top;

					nodes.forEach((node, idx) => {
						if (node.isStatic) return;
						const dist = Math.hypot(node.x - mouseX, node.y - mouseY);
						if (dist < node.radius + 10) {
							selectedNode = idx;
						}
					});
				});

				canvas.addEventListener('mousemove', (e) => {
					if (selectedNode === null) return;
					const rect = canvas.getBoundingClientRect();
					const mouseX = e.clientX - rect.left;
					const mouseY = e.clientY - rect.top;

					nodes[selectedNode].x = mouseX;
					nodes[selectedNode].y = mouseY;
					nodes[selectedNode].vx = 0;
					nodes[selectedNode].vy = 0;
				});

				const stopDrag = () => { selectedNode = null; };
				canvas.addEventListener('mouseup', stopDrag);
				canvas.addEventListener('mouseleave', stopDrag);
				
				canvas.addEventListener('dblclick', () => {
					initPhysics();
				});

				document.getElementById('resetBtn')?.addEventListener('click', () => {
					initPhysics();
				});

				// Physics Engine Loop
				function updatePhysics() {
					const gravity = 0.15;
					const damping = 0.94;

					// Apply gravity and damping to nodes
					nodes.forEach((node) => {
						if (node.isStatic) return;
						node.vy += gravity;
						node.x += node.vx;
						node.y += node.vy;
						node.vx *= damping;
						node.vy *= damping;

						// Wall bounce constraints
						if (node.x < node.radius) { node.x = node.radius; node.vx *= -0.5; }
						if (node.x > width - node.radius) { node.x = width - node.radius; node.vx *= -0.5; }
						if (node.y < node.radius) { node.y = node.radius; node.vy *= -0.5; }
						if (node.y > height - node.radius) { node.y = height - node.radius; node.vy *= -0.5; }
					});

					// Apply cable tension constraints (Spring forces)
					for (let i = 0; i < 4; i++) { // Run multiple solver iterations for stiff cables
						cables.forEach((cable) => {
							const from = nodes[cable.fromIdx];
							const to = nodes[cable.toIdx];
							const dx = to.x - from.x;
							const dy = to.y - from.y;
							const dist = Math.hypot(dx, dy) || 0.1;
							const delta = dist - cable.restLength;

							// Force proportional to delta
							const force = delta * cable.stiffness * 0.5;
							const offsetX = (dx / dist) * force;
							const offsetY = (dy / dist) * force;

							if (!from.isStatic) {
								from.x += offsetX;
								from.y += offsetY;
							}
							if (!to.isStatic) {
								to.x -= offsetX;
								to.y -= offsetY;
							}
						});
					}
				}

				function draw() {
					if (!ctx) return;
					ctx.clearRect(0, 0, width, height);

					// Draw cables
					cables.forEach((cable) => {
						const from = nodes[cable.fromIdx];
						const to = nodes[cable.toIdx];
						const dist = Math.hypot(to.x - from.x, to.y - from.y);
						
						// Highlight cable colors if they are under heavy tension
						const tensionRatio = Math.abs(dist - cable.restLength) / cable.restLength;
						ctx.beginPath();
						ctx.moveTo(from.x, from.y);
						ctx.lineTo(to.x, to.y);
						
						if (tensionRatio > 0.1) {
							ctx.strokeStyle = `rgba(6, 182, 212, ${Math.min(0.3 + tensionRatio * 3, 0.9)})`;
							ctx.lineWidth = 2 + tensionRatio * 3;
						} else {
							ctx.strokeStyle = cable.color;
							ctx.lineWidth = 1.5;
						}
						
						ctx.setLineDash([5, 5]);
						ctx.stroke();
						ctx.setLineDash([]);
					});

					// Draw nodes
					nodes.forEach((node) => {
						// Outer glow
						const glow = ctx.createRadialGradient(node.x, node.y, 2, node.x, node.y, node.radius + 10);
						glow.addColorStop(0, node.color);
						glow.addColorStop(1, 'rgba(0,0,0,0)');
						
						ctx.beginPath();
						ctx.arc(node.x, node.y, node.radius + 10, 0, Math.PI * 2);
						ctx.fillStyle = glow;
						ctx.fill();

						// Node body
						ctx.beginPath();
						ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
						ctx.fillStyle = node.isStatic ? '#111827' : node.color;
						ctx.strokeStyle = node.color;
						ctx.lineWidth = 2;
						ctx.fill();
						ctx.stroke();

						// Node text label
						ctx.fillStyle = '#f3f4f6';
						ctx.font = 'bold 9px monospace';
						ctx.textAlign = 'center';
						ctx.fillText(node.label, node.x, node.y - node.radius - 6);
					});
				}

				function loop() {
					updatePhysics();
					draw();
					requestAnimationFrame(loop);
				}

				loop();
			});
		</script>
