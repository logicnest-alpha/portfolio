---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 3); // Get latest 3 blog posts
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Page-Specific Animations and Styles */
			.tensegrity-grid-bg {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background-image: 
					radial-gradient(var(--accent-primary-glow) 1px, transparent 1px),
					radial-gradient(var(--accent-secondary-glow) 1px, transparent 1px);
				background-size: 30px 30px;
				background-position: 0 0, 15px 15px;
				opacity: 0.15;
				pointer-events: none;
			}
			
			.hero-title-container {
				text-align: center;
				padding: 4rem 0 2rem 0;
				position: relative;
			}

			.hero-badge {
				font-family: monospace;
				font-size: 0.8rem;
				color: var(--accent-secondary);
				border: 1px solid rgba(6, 182, 212, 0.3);
				padding: 0.3rem 0.8rem;
				border-radius: 9999px;
				background: rgba(6, 182, 212, 0.05);
				display: inline-block;
				margin-bottom: 1rem;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}

			.hero-title {
				font-size: 3.5rem;
				font-weight: 800;
				line-height: 1.1;
				background: linear-gradient(to right, #ffffff 40%, var(--accent-primary) 70%, var(--accent-secondary) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin-bottom: 1.5rem;
				letter-spacing: -0.03em;
			}

			.hero-desc {
				font-size: 1.15rem;
				max-width: 650px;
				margin: 0 auto;
				color: var(--text-secondary);
			}

			/* Three Tier Floating Tensegrity Layout */
			.tensegrity-tower {
				display: flex;
				flex-direction: column;
				gap: 5rem;
				margin: 3rem 0;
				position: relative;
			}

			/* Tier Titles */
			.tier-header {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 1.5rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				padding-bottom: 0.5rem;
			}

			.tier-num {
				font-family: monospace;
				font-size: 0.75rem;
				color: var(--accent-primary);
				background: rgba(139, 92, 246, 0.1);
				border: 1px solid rgba(139, 92, 246, 0.2);
				padding: 0.1rem 0.5rem;
				border-radius: 4px;
			}

			.tier-title {
				font-size: 1.25rem;
				text-transform: uppercase;
				letter-spacing: 0.075em;
				font-weight: 700;
			}

			.tier-subtitle {
				color: var(--text-muted);
				font-size: 0.85rem;
				margin-left: auto;
				font-family: monospace;
			}

			/* TIER 3: The Vault */
			.vault-container {
				padding: 1.5rem;
			}
			
			.terminal-list {
				display: flex;
				flex-direction: column;
				gap: 1rem;
				font-family: monospace;
			}

			.terminal-item {
				display: flex;
				align-items: flex-start;
				gap: 1rem;
				padding: 0.75rem 1rem;
				border-radius: 8px;
				background: rgba(3, 3, 7, 0.5);
				border: 1px solid rgba(255, 255, 255, 0.03);
				transition: all 0.2s ease;
			}

			.terminal-item:hover {
				border-color: rgba(6, 182, 212, 0.2);
				background: rgba(6, 182, 212, 0.02);
			}

			.term-prompt {
				color: var(--accent-secondary);
				user-select: none;
			}

			.term-date {
				color: var(--text-muted);
			}

			.term-title {
				color: var(--text-primary);
				font-weight: bold;
				text-decoration: none;
			}

			.term-title:hover {
				color: var(--accent-secondary);
			}

			/* TIER 2: Flagship Engine Projects */
			.projects-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
			}

			.project-card {
				padding: 2rem;
				display: flex;
				flex-direction: column;
				gap: 1.25rem;
				position: relative;
				overflow: hidden;
			}

			.project-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				width: 4px;
				height: 100%;
				background: var(--accent-primary);
				opacity: 0.5;
				transition: all 0.3s ease;
			}

			.project-card:hover::before {
				height: 100%;
				background: var(--accent-secondary);
				opacity: 1;
				box-shadow: 0 0 15px var(--accent-secondary);
			}

			.project-meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.project-node {
				font-family: monospace;
				font-size: 0.75rem;
				background: rgba(255, 255, 255, 0.05);
				border: 1px solid rgba(255, 255, 255, 0.08);
				padding: 0.2rem 0.5rem;
				border-radius: 4px;
				color: var(--text-secondary);
			}

			.project-status {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				font-size: 0.7rem;
				text-transform: uppercase;
				font-family: monospace;
				letter-spacing: 0.05em;
				color: var(--accent-success);
			}

			.project-status-dot {
				width: 5px;
				height: 5px;
				background-color: var(--accent-success);
				border-radius: 50%;
				box-shadow: 0 0 8px var(--accent-success);
			}

			.project-title {
				font-size: 1.5rem;
				font-weight: 700;
			}

			.project-desc {
				font-size: 0.9rem;
				color: var(--text-secondary);
				line-height: 1.6;
			}

			.project-edge-title {
				font-weight: 700;
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: var(--accent-primary);
				margin-bottom: 0.4rem;
			}

			.project-edge-list {
				list-style-type: none;
				padding-left: 0;
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}

			.project-edge-item {
				font-size: 0.85rem;
				color: var(--text-secondary);
				display: flex;
				align-items: flex-start;
				gap: 0.5rem;
			}

			.project-edge-item::before {
				content: "→";
				color: var(--accent-secondary);
			}

			.vibe-badge {
				background: rgba(236, 72, 153, 0.08);
				border: 1px solid rgba(236, 72, 153, 0.2);
				border-radius: 8px;
				padding: 0.75rem 1rem;
				font-size: 0.8rem;
				color: #f472b6;
				line-height: 1.5;
				margin-top: auto;
			}

			.project-footer {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-top: auto;
				padding-top: 1rem;
				border-top: 1px solid rgba(255, 255, 255, 0.03);
			}

			.project-tech {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
			}

			.tech-tag {
				font-size: 0.7rem;
				font-family: monospace;
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(255, 255, 255, 0.06);
				color: var(--text-muted);
				padding: 0.15rem 0.4rem;
				border-radius: 4px;
			}

			.project-link {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				font-size: 0.8rem;
				font-weight: 600;
				color: var(--text-primary);
				border: 1px solid rgba(255, 255, 255, 0.08);
				padding: 0.4rem 0.8rem;
				border-radius: 6px;
				background: rgba(255, 255, 255, 0.02);
				transition: all 0.2s ease;
			}

			.project-link:hover {
				color: var(--accent-secondary);
				border-color: rgba(6, 182, 212, 0.3);
				background: rgba(6, 182, 212, 0.05);
			}

			/* TIER 1: The Foundation Anchor Base */
			.foundation-grid {
				display: grid;
				grid-template-columns: 1.2fr 1fr;
				gap: 2rem;
			}

			.bio-panel {
				padding: 2.5rem;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.bio-name {
				font-size: 2rem;
				font-weight: 800;
			}

			.bio-subtitle {
				font-family: monospace;
				font-size: 0.9rem;
				color: var(--accent-secondary);
			}

			.bio-text {
				font-size: 0.95rem;
				line-height: 1.7;
				color: var(--text-secondary);
			}

			.skills-panel {
				padding: 2.5rem;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.skills-section-title {
				font-size: 0.85rem;
				text-transform: uppercase;
				font-weight: 700;
				letter-spacing: 0.075em;
				color: var(--accent-primary);
				margin-bottom: 0.5rem;
			}

			.skills-list {
				display: flex;
				flex-direction: column;
				gap: 1.25rem;
			}

			.skill-group {
				border-left: 2px solid rgba(255, 255, 255, 0.05);
				padding-left: 1rem;
			}

			.skill-group-title {
				font-size: 0.95rem;
				font-weight: bold;
				margin-bottom: 0.4rem;
				color: var(--text-primary);
			}

			.skill-group-items {
				font-size: 0.85rem;
				color: var(--text-secondary);
				line-height: 1.5;
			}

			/* Resume Core */
			.resume-core {
				grid-column: span 2;
				padding: 2.5rem;
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}

			.resume-title {
				font-size: 1.5rem;
				font-weight: 700;
			}

			.timeline {
				display: flex;
				flex-direction: column;
				gap: 2rem;
				position: relative;
			}

			.timeline::before {
				content: '';
				position: absolute;
				top: 0;
				left: 9px;
				height: 100%;
				width: 2px;
				background: rgba(255, 255, 255, 0.05);
			}

			.timeline-item {
				position: relative;
				padding-left: 2.5rem;
			}

			.timeline-dot {
				position: absolute;
				left: 4px;
				top: 6px;
				width: 12px;
				height: 12px;
				border-radius: 50%;
				background: var(--bg-primary);
				border: 3px solid var(--accent-primary);
			}

			.timeline-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 0.5rem;
			}

			.timeline-org {
				font-size: 1.1rem;
				font-weight: 700;
				color: var(--text-primary);
			}

			.timeline-role {
				font-size: 0.9rem;
				color: var(--accent-secondary);
				font-family: monospace;
			}

			.timeline-date {
				font-size: 0.8rem;
				color: var(--text-muted);
				font-family: monospace;
			}

			.timeline-desc {
				font-size: 0.9rem;
				color: var(--text-secondary);
				line-height: 1.6;
			}

			.timeline-bullets {
				list-style-type: none;
				padding-left: 0;
				margin-top: 0.5rem;
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}

			.timeline-bullet {
				font-size: 0.85rem;
				color: var(--text-secondary);
				display: flex;
				align-items: flex-start;
				gap: 0.5rem;
			}

			.timeline-bullet::before {
				content: "⚡";
				font-size: 0.75rem;
				color: var(--accent-primary);
			}

			/* Tension Cables Visualizer Widget */
			.tensegrity-widget-container {
				margin-top: 4rem;
				padding: 2rem;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				position: relative;
				overflow: hidden;
			}

			.widget-canvas-container {
				width: 100%;
				height: 300px;
				border-radius: 12px;
				background: rgba(3, 3, 7, 0.8);
				border: 1px solid rgba(255, 255, 255, 0.05);
				position: relative;
				overflow: hidden;
			}

			.widget-canvas {
				width: 100%;
				height: 100%;
				cursor: grab;
			}

			.widget-canvas:active {
				cursor: grabbing;
			}

			.widget-controls {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.8rem;
				color: var(--text-muted);
				font-family: monospace;
			}

			.control-btn {
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(255, 255, 255, 0.08);
				color: var(--text-secondary);
				padding: 0.3rem 0.8rem;
				border-radius: 4px;
				cursor: pointer;
				transition: all 0.2s ease;
			}

			.control-btn:hover {
				color: var(--accent-secondary);
				border-color: rgba(6, 182, 212, 0.3);
				background: rgba(6, 182, 212, 0.05);
			}

			@media (max-width: 900px) {
				.projects-grid {
					grid-template-columns: 1fr;
				}
				.foundation-grid {
					grid-template-columns: 1fr;
				}
				.resume-core {
					grid-column: span 1;
				}
			}

			@media (max-width: 600px) {
				.hero-title {
					font-size: 2.25rem;
				}
				.timeline-header {
					flex-direction: column;
					gap: 0.25rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="position: relative;">
			<div class="tensegrity-grid-bg"></div>

			<!-- Connection Cable Overlays -->
			<!-- Using SVGs to render responsive connectors that dynamically illuminate based on card actions -->
			<svg class="cable-overlay" id="cable-overlay" viewBox="0 0 1200 1600" preserveAspectRatio="none">
				<!-- Tier 3 to Tier 2 connections -->
				<path class="cable-line" id="cable-t3-a" d="M 600,280 Q 400,380 300,450" />
				<path class="cable-line" id="cable-t3-b" d="M 600,280 Q 500,380 900,450" />
				<path class="cable-line" id="cable-t3-c" d="M 600,280 Q 450,450 300,800" />
				<path class="cable-line" id="cable-t3-d" d="M 600,280 Q 750,450 900,800" />

				<!-- Tier 2 to Tier 1 connections -->
				<path class="cable-line" id="cable-a-t1" d="M 300,750 Q 250,900 350,1100" />
				<path class="cable-line" id="cable-b-t1" d="M 900,750 Q 950,900 850,1100" />
				<path class="cable-line" id="cable-c-t1" d="M 300,1050 Q 400,1150 450,1100" />
				<path class="cable-line" id="cable-d-t1" d="M 900,1050 Q 800,1150 750,1100" />
			</svg>

			<section class="hero-title-container">
				<span class="hero-badge">Astro Engineering Core v2.0</span>
				<h1 class="hero-title">Suspended by Tension,<br />Driven by Code.</h1>
				<p class="hero-desc">
					Vishal Chepyala is a CSE builder designing systems where hardware meets AI-assisted software. Constructing high-output automation, local IoT bridges, and decentralized platforms.
				</p>
			</section>

			<div class="tensegrity-tower">
				
				<!-- TIER 3: THE VAULT / DAILY BLOG -->
				<div class="tier-wrapper" id="tier-3">
					<div class="tier-header">
						<span class="tier-num">Tier 03</span>
						<h2 class="tier-title">The Vault / Daily Blog</h2>
						<span class="tier-subtitle">status: suspended_log_output</span>
					</div>
					<div class="glass-panel vault-container">
						<div class="terminal-list">
							{posts.map((post) => (
								<div class="terminal-item">
									<span class="term-prompt">$</span>
									<span class="term-date">[{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' })}]</span>
									<span class="term-prompt">cat</span>
									<a href={`/blog/${post.id}/`} class="term-title">
										{post.data.title}
									</a>
									<span style="color: var(--text-muted); margin-left: 0.5rem;">- {post.data.description}</span>
								</div>
							))}
							<div class="terminal-item" style="opacity: 0.7;">
								<span class="term-prompt">$</span>
								<span class="term-date">[System]</span>
								<span class="term-prompt">uptime</span>
								<span style="color: var(--accent-success);">Grid suspended successfully. 4 nodes balanced in tension.</span>
							</div>
						</div>
					</div>
				</div>

				<!-- TIER 2: THE FLAGSHIP ENGINE PROJECTS -->
				<div class="tier-wrapper" id="tier-2">
					<div class="tier-header">
						<span class="tier-num">Tier 02</span>
						<h2 class="tier-title">Flagship Engine Projects</h2>
						<span class="tier-subtitle">status: balancing_compression</span>
					</div>
					
					<div class="projects-grid">
						
						<!-- Project 1: MiRobot Studio -->
						<div class="glass-panel project-card" id="project-node-a" data-cable-ids="cable-t3-a,cable-a-t1">
							<div class="project-meta">
								<span class="project-node">Node A // System Control</span>
								<div class="project-status">
									<span class="project-status-dot"></span>
									<span>Active Dev</span>
								</div>
							</div>
							<h3 class="project-title">MiRobot Studio // Reverse Engineering Xiaomi Vacuum</h3>
							<p class="project-desc">
								Reverse engineered a Xiaomi Mi Robot Vacuum-Mop 2 Pro (<code>ijai.vacuum.v15</code>) to enable complete local control without relying on the official mobile application. Extracted device authentication tokens, analyzed the MIoT protocol, and built a modular Python SDK dashboard for scanning and controlling action execution.
							</p>
							<div>
								<h4 class="project-edge-title">The Tech Edge</h4>
								<ul class="project-edge-list">
									<li class="project-edge-item">Discovered MIoT property actions and local token-based UDP communication</li>
									<li class="project-edge-item">Built modular SDK scanning properties, locators, and battery logs</li>
									<li class="project-edge-item">Designed Flask system dashboard for local reverse engineered telemetry</li>
								</ul>
							</div>
							<div class="project-footer">
								<div class="project-tech">
									<span class="tech-tag">Python</span>
									<span class="tech-tag">python-miio</span>
									<span class="tech-tag">MIIO/MIoT</span>
									<span class="tech-tag">Flask</span>
									<span class="tech-tag">UDP/IP</span>
								</div>
								<a href="https://github.com/logicnest-alpha" target="_blank" class="project-link">
									GitHub
								</a>
							</div>
						</div>

						<!-- Project 2: NutriGuard AI -->
						<div class="glass-panel project-card" id="project-node-b" data-cable-ids="cable-t3-b,cable-b-t1">
							<div class="project-meta">
								<span class="project-node">Node B // Sensory Hardware</span>
								<div class="project-status">
									<span class="project-status-dot"></span>
									<span>IoT Edge Active</span>
								</div>
							</div>
							<h3 class="project-title">NutriGuard AI // Intelligent Food Analytics</h3>
							<p class="project-desc">
								Coordinated a hardware-software co-design system utilizing sensory arrays to detect environmental and chemical freshness markers in food items. Processed edge-sensor inputs through an intelligent analytical backend model to output real-time decay timelines, safety metrics, and complete nutritional breakdowns.
							</p>
							<div>
								<h4 class="project-edge-title">The Tech Edge</h4>
								<ul class="project-edge-list">
									<li class="project-edge-item">Sensor Data Fusion (ESP32, MQ-135, DHT22) for gas and moisture tracking</li>
									<li class="project-edge-item">Edge integration with Groq AI Large Language Model backend orchestration</li>
									<li class="project-edge-item">Generated decay timelines, organic deterioration indexes, and nutrition charts</li>
								</ul>
							</div>
							<div class="project-footer">
								<div class="project-tech">
									<span class="tech-tag">ESP32</span>
									<span class="tech-tag">C++ / Arduino</span>
									<span class="tech-tag">Sensors</span>
									<span class="tech-tag">Groq AI</span>
									<span class="tech-tag">Data Fusion</span>
								</div>
								<a href="https://github.com/logicnest-alpha" target="_blank" class="project-link">
									GitHub
								</a>
							</div>
						</div>

						<!-- Project 3: LeadGen Crawler -->
						<div class="glass-panel project-card" id="project-node-c" data-cable-ids="cable-t3-c,cable-c-t1">
							<div class="project-meta">
								<span class="project-node">Node C // Automation Engine</span>
								<div class="project-status">
									<span class="project-status-dot"></span>
									<span>Deployed</span>
								</div>
							</div>
							<h3 class="project-title">LeadGen AI Personalization Crawler</h3>
							<p class="project-desc">
								Developed a production-grade data scraping architecture that bypasses standard rate limits to extract target B2B leads from the Google Maps ecosystem. Integrated this pipeline with a Large Language Model (LLM) orchestration layer to automatically parse business metrics and generate highly personalized outreach text.
							</p>
							<div class="vibe-badge">
								⚡ Leveraged advanced AI-assisted engineering (Vibe Coding) to reduce standard software development lifecycle (SDLC) timelines by 70%, moving from conceptual design to functional GitHub deployment in hours.
							</div>
							<div>
