---
const today = new Date();
---

<footer class="glass-footer">
	<div class="footer-content">
		<div class="copyright">
			&copy; {today.getFullYear()} Vishal Chepyala. All rights reserved.
		</div>
		<div class="system-status">
			<span class="status-pulse"></span>
			<span class="status-text">All systems functional // Anti-gravity grid active</span>
		</div>
		<div class="social-links">
			<a href="https://github.com/logicnest-alpha" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</div>
</footer>

<style>
	.glass-footer {
		background: rgba(5, 5, 12, 0.9);
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		padding: 2rem 1.5rem;
		margin-top: 4rem;
	}
	
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		text-align: center;
	}
	
	.copyright {
		color: var(--text-muted);
		font-size: 0.85rem;
	}
	
	.system-status {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: monospace;
		font-size: 0.75rem;
		background: rgba(16, 185, 129, 0.05);
		border: 1px solid rgba(16, 185, 129, 0.15);
		padding: 0.3rem 0.8rem;
		border-radius: 9999px;
		color: var(--accent-success);
	}
	
	.status-pulse {
		display: inline-block;
		width: 6px;
		height: 6px;
		background-color: var(--accent-success);
		border-radius: 50%;
		animation: pulse-slow 1.5s ease-in-out infinite;
	}
	
	.social-links {
		display: flex;
		gap: 1rem;
		margin-top: 0.5rem;
	}
	
	.social-links a {
		color: var(--text-muted);
		transition: all 0.2s ease;
	}
	
	.social-links a:hover {
		color: var(--accent-secondary);
	}
</style>
