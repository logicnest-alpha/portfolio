---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="glass-header">
	<nav>
		<div class="logo">
			<a href="/">
				<span class="logo-text">{SITE_TITLE}</span>
				<span class="logo-badge">ENGINE</span>
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/logicnest-alpha" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	.glass-header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(10, 10, 22, 0.7);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		padding: 0 2rem;
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
	}
	
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		height: 4rem;
	}
	
	.logo a {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
	}
	
	.logo-text {
		font-weight: 800;
		font-size: 1.25rem;
		background: linear-gradient(135deg, var(--text-primary) 30%, var(--accent-secondary) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		letter-spacing: -0.025em;
	}
	
	.logo-badge {
		font-size: 0.65rem;
		font-weight: 700;
		background: rgba(6, 182, 212, 0.15);
		color: var(--accent-secondary);
		border: 1px solid rgba(6, 182, 212, 0.3);
		padding: 0.1rem 0.4rem;
		border-radius: 4px;
		letter-spacing: 0.05em;
	}
	
	.internal-links {
		display: flex;
		gap: 1.5rem;
	}
	
	.internal-links :global(a) {
		color: var(--text-secondary);
		font-size: 0.9rem;
		font-weight: 500;
		text-decoration: none;
		padding: 0.5rem 0.25rem;
		border-bottom: 2px solid transparent;
		transition: all 0.2s ease;
	}
	
	.internal-links :global(a:hover) {
		color: var(--text-primary);
	}
	
	.internal-links :global(a.active) {
		color: var(--accent-primary);
		border-bottom-color: var(--accent-primary);
	}
	
	.social-links {
		display: flex;
		align-items: center;
	}
	
	.social-links a {
		color: var(--text-secondary);
		padding: 0.5rem;
		border-radius: 8px;
		transition: all 0.2s ease;
		border: 1px solid transparent;
	}
	
	.social-links a:hover {
		color: var(--accent-secondary);
		background: rgba(6, 182, 212, 0.08);
		border-color: rgba(6, 182, 212, 0.2);
	}
	
	@media (max-width: 640px) {
		.social-links {
			display: none;
		}
		.glass-header {
			padding: 0 1rem;
		}
	}
</style>
